FROM rust:1-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
        libprotobuf-dev \
        pkg-config \
        protobuf-compiler \
        python3 \
    && rm -rf /var/lib/apt/lists/*

ENV CARGO_TERM_COLOR=always
ENV CARGO_BUILD_JOBS=1
ENV PYTHONDONTWRITEBYTECODE=1

WORKDIR /workspace

CMD ["bash", "crates/rig-sqlite/tests/fixtures/run_vector_validation.sh"]
